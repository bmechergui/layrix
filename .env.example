# ============================================================
# Layrix — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# Anthropic (agents Claude)
ANTHROPIC_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Redis (Upstash ou Railway)
REDIS_URL=

# Lemon Squeezy (paiement)
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Service KiCad (Docker, Railway ou DigitalOcean)
KICAD_SERVICE_URL=http://localhost:8000

# Email (Resend)
RESEND_API_KEY=

# SnapMagic (footprints)
SNAPMAGIC_API_KEY=

# Octopart (composants)
OCTOPART_API_KEY=

# URL publiques apps
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3002
